# ============================================================
# weid.fun · .gitignore (main / framework 分支)
# ============================================================
# 这个文件在 main 分支上排除所有个人内容，使得 main 可以作为
# 纯粹的「框架代码」开源。
#
# personal 分支的 .gitignore 是这份的子集 —— 它不包含
# 「个人内容」那一段，从而让博客文章、rules、references
# 在 personal 分支被追踪。
#
# 合并方向：main → personal（框架更新流向博客）
# 禁止：personal → main（防止个人内容污染框架）
# ============================================================

# -------- 构建产物 --------
/dist/
/build/
*.log

# -------- 依赖 --------
/node_modules/
/.pnp
.pnp.js

# -------- 运行时 --------
/.cache/
/.vite/
/.tsbuildinfo
*.tsbuildinfo

# -------- 编辑器 / OS --------
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo

# -------- 环境变量 --------
.env
.env.local
.env.*.local
!.env.example

# -------- Brainstorming / Superpowers --------
/.superpowers/

# -------- oh-my-claudecode session state --------
/.omc/

# -------- 文件夹模式的暂存区（永远本地） --------
/inbox/
